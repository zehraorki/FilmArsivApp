@model FilmArsivApp.Models.FilmVeriModeli

@{
    ViewData["Title"] = "Film Düzenle";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow p-4 border-0">
        <h3 class="text-primary mb-4"><i class="bi bi-pencil-square"></i> Film Bilgilerini Güncelle</h3>
        
        <form asp-action="Guncelle" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="MevcutAfisYolu" />

            <div class="mb-3">
                <label asp-for="FilmAdi" class="form-label">Film Adı</label>
                <input asp-for="FilmAdi" class="form-control" />
                <span asp-validation-for="FilmAdi" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Tur" class="form-label">Tür</label>
                    <input asp-for="Tur" class="form-control" />
                    <span asp-validation-for="Tur" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="YayinYili" class="form-label">Yayın Yılı</label>
                    <input asp-for="YayinYili" class="form-control" type="number" />
                    <span asp-validation-for="YayinYili" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Aciklama" class="form-label">Açıklama</label>
                    <input asp-for="Aciklama" class="form-control" />
                    <span asp-validation-for="Aciklama" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Puan" class="form-label">IMDb Puanı</label>
                    <input asp-for="Puan" class="form-control" type="number" step="0.1" />
                    <span asp-validation-for="Puan" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-4 d-flex align-items-center gap-3">
                <div class="flex-grow-1">
                    <label asp-for="AfisDosyasi" class="form-label">Yeni Afiş Yükle (Değiştirmek istemiyorsanız boş bırakın)</label>
                    <input asp-for="AfisDosyasi" class="form-control" type="file" accept="image/*" />
                </div>
                @if (!string.IsNullOrEmpty(Model.MevcutAfisYolu))
                {
                    <div>
                        <p class="mb-1 text-muted" style="font-size: 0.8rem;">Mevcut Afiş:</p>
                        <img src="~/afisler/@Model.MevcutAfisYolu" style="height: 70px; border-radius: 4px;" />
                    </div>
                }
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Değişiklikleri Kaydet</button>
                <a asp-action="Listele" class="btn btn-light border">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}